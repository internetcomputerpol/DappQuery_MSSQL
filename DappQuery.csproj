  <ItemGroup>
    <Content Include="canister.ico" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="EdjCase.ICP.Agent" Version="8.0.0-pre.1" />
  </ItemGroup>

</Project>
